<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/transparent">

    <ImageButton
        android:id="@+id/btnAutoAttack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/auto_button_bg"
        android:src="@drawable/auto_attack_icon"
        android:scaleType="centerInside"
        android:contentDescription="Auto Attack" />

    <ImageButton
        android:id="@+id/btnAutoHeal"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/auto_button_bg"
        android:src="@drawable/auto_heal_icon"
        android:scaleType="centerInside"
        android:contentDescription="Auto Heal" />

    <ImageButton
        android:id="@+id/btnAutoMana"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/auto_button_bg"
        android:src="@drawable/auto_mana_icon"
        android:scaleType="centerInside"
        android:contentDescription="Auto Mana" />

</LinearLayout>